# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# ── Server ────────────────────────────────────────────────────────────────────
# Address to bind (0.0.0.0 = all interfaces)
HOST=0.0.0.0
PORT=8765

# Path to source face image or folder of images (same identity).
# Leave blank to require the client to send it at runtime.
SOURCE_PATH=

# ── Client ────────────────────────────────────────────────────────────────────
# Full WebSocket URL of the server
SERVER_URL=ws://CHANGE_ME:8765/ws

# Camera device index (0 = default webcam)
CAMERA_INDEX=0
CAPTURE_WIDTH=1280
CAPTURE_HEIGHT=720
